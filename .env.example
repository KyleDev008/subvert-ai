# ── Ollama Cloud ─────────────────────────────────────────────────────────────
# Base URL for Ollama Cloud API (no trailing slash)
OLLAMA_CLOUD_URL=https://ollama.com

# Your Ollama Cloud API key — get it at https://ollama.com (account settings)
OLLAMA_CLOUD_KEY=your_api_key_here

# ── Proxy Server ──────────────────────────────────────────────────────────────
# Port the local proxy listens on (update VS Code config URL if you change this)
PORT=11435

# Bind address — 0.0.0.0 makes it accessible on all network interfaces
# Use 127.0.0.1 to restrict to localhost only
HOST=0.0.0.0

# ── Local Ollama (optional) ───────────────────────────────────────────────────
# Set to true to enable the local Ollama proxy server
LOCAL_OLLAMA_ENABLED=false

# Base URL of your local Ollama instance
LOCAL_OLLAMA_URL=http://localhost:11434

# Port the local Ollama proxy listens on (use this in VS Code config URLs)
LOCAL_OLLAMA_PORT=11436

# ── Multi-Mode (optional) ──────────────────────────────────────────────────────
# Set to true to enable multiple named API keys (managed via the Settings UI)
MULTI_MODE=false

# JSON array of named keys — managed automatically by the Settings UI, do not edit by hand
# Format: [{"name":"Personal","key":"sk-..."},{"name":"Work","key":"sk-..."}]
MULTI_MODE_KEYS=[]

# Index of the currently active key in MULTI_MODE_KEYS (0-based)
ACTIVE_KEY_INDEX=0
